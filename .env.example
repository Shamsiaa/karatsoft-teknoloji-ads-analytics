# Server Configuration
PORT=3000

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=ads_db

# Apple Ads API Configuration
APPLE_TEAM_ID=your_team_id
APPLE_CLIENT_ID=your_client_id
APPLE_KEY_ID=your_key_id
APPLE_PRIVATE_KEY_PATH=./private-key.pem
APPLE_ADS_SCOPE=searchadsorg
APPLE_ADS_ORG_ID=123456789

# Google Ads API Configuration
GOOGLE_ADS_CLIENT_ID=your_google_client_id
GOOGLE_ADS_CLIENT_SECRET=your_google_client_secret
GOOGLE_ADS_DEVELOPER_TOKEN=your_google_developer_token
GOOGLE_ADS_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_ADS_CUSTOMER_ID=1234567890
GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890
GOOGLE_ADS_API_VERSION=v18

# Daily Scheduler (UTC)
DAILY_SYNC_ENABLED=false
DAILY_SYNC_TIME_UTC=02:00
DAILY_SYNC_RUN_ON_STARTUP=false

# Direct store revenue integrations (mentor model)
APP_STORE_CONNECT_ISSUER_ID=your_issuer_id
APP_STORE_CONNECT_KEY_ID=your_key_id
APP_STORE_CONNECT_PRIVATE_KEY_PATH=./appstore-connect-key.p8
APP_STORE_CONNECT_VENDOR_NUMBER=your_vendor_number

GOOGLE_PLAY_SERVICE_ACCOUNT_KEY_PATH=./google-play-service-account.json
GOOGLE_PLAY_REPORTS_BUCKET=your_play_reports_bucket
GOOGLE_PLAY_REPORTS_PREFIX=earnings/

DAILY_STORE_REVENUE_SYNC_ENABLED=false
STORE_REVENUE_SYNC_APP_KEYS=photoverse
STORE_REVENUE_WRITE_SUMMARY=false

# Historical backfill: runs from start date backward to end date (inclusive)
HISTORICAL_BACKFILL_ENABLED=false
HISTORICAL_BACKFILL_RUN_ON_STARTUP=false
HISTORICAL_BACKFILL_START_DATE=2026-03-05
HISTORICAL_BACKFILL_END_DATE=2025-01-01
HISTORICAL_BACKFILL_MAX_DAYS=500
HISTORICAL_BACKFILL_INCLUDE_STORE_REVENUE=true
HISTORICAL_BACKFILL_INCLUDE_EXCHANGE_RATES=true

# Exchange rates (base TRY -> target currency)
DAILY_EXCHANGE_RATE_SYNC_ENABLED=true
EXCHANGE_RATE_TARGET_CURRENCY=USD

# Unified externally-triggered sync-all endpoint
SYNC_ALL_BACKFILL_CHUNK_DAYS=30
SYNC_ALL_BACKFILL_FLOOR_DATE=2025-01-01
SYNC_ALL_DELAY_MS=750
